# ─── LangGraph / LangSmith ────────────────────────────────────────────────────
# Traces are grouped under this project name in LangSmith
LANGSMITH_PROJECT=andromeda-agent

# LangSmith API key (required for LangGraph API authentication)
LANGSMITH_API_KEY=

# Groq API key (required for the LLM)
GROQ_API_KEY=

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your login password)
GMAIL_SMTP_USER=your.email@gmail.com
GMAIL_APP_PASSWORD="your-16-char-app-password"
GMAIL_DEFAULT_RECIPIENT=your.email@gmail.com
# Optional overrides (defaults: smtp.gmail.com / 587)
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=587

# ─── Railway Deployment ───────────────────────────────────────────────────────
# Railway sets PORT automatically — leave at 8000 for local
PORT=8000

# CORS: comma-separated list of allowed frontend origins.
# Set this in Railway → Variables so the Vercel frontend can call the API.
# LangGraph server reads CORS_ALLOW_ORIGINS (not LANGGRAPH_ALLOWED_ORIGINS).
# Example: https://andromedatoolcallingagentui.vercel.app,http://localhost:5173
CORS_ALLOW_ORIGINS=https://andromedatoolcallingagentui.vercel.app,http://localhost:5173
