# Andromeda Tool Calling Agent — Environment Variables
# Copy this file and fill in your values:
#   cp .env.example .env
#
# Never commit .env, client_secret.json, or gmail_token.json.

# ─── Required: Groq LLM ───────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-8b-8192

# ─── Optional: LangSmith tracing / authenticated LangGraph ────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=new-agent

# ─── Gmail OAuth inbox automation ─────────────────────────────────────────────
# Download OAuth Desktop client JSON from Google Cloud Console.
GOOGLE_CLIENT_SECRETS=client_secret.json
GMAIL_TOKEN_FILE=gmail_token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify
GMAIL_USER_ID=me
GMAIL_INBOX_QUERY=is:unread in:inbox
# Max unread messages per run (0 = no limit)
GMAIL_PROCESS_LIMIT=0

# ─── Ollama fallback for Gmail reply generation ───────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
OLLAMA_MAX_TOKENS=512

# ─── Optional legacy SMTP helper (outbound email reports) ─────────────────────
GMAIL_SMTP_USER=your.email@gmail.com
GMAIL_APP_PASSWORD="abcd efgh ijkl mnop"
GMAIL_DEFAULT_RECIPIENT=your.email@gmail.com
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
# Aliases also accepted: SMTP_USERNAME, SMTP_PASSWORD, SMTP_TO_EMAIL

# ─── Location (OpenStreetMap) ─────────────────────────────────────────────────
OSM_USER_AGENT=AndromedaAgent/0.1 (your-contact@example.com)

# ─── Logging & local service ports ────────────────────────────────────────────
LOG_LEVEL=INFO
LANGGRAPH_PORT=2024
STREAMLIT_PORT=8501
FRONTEND_PORT=5173

# ─── CORS (LangGraph API — comma-separated, no spaces) ────────────────────────
# Allows local Streamlit (8501), Vite (5173), LangGraph Studio, and optional Vercel.
# Also mirrored in langgraph.json allow_origins for `langgraph dev`.
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:5173,http://127.0.0.1:5173,http://localhost:2024,http://127.0.0.1:2024,https://smith.langchain.com,https://andromedatoolcallingagent.vercel.app

# ─── Frontend (Vite loads these from the repo root via envDir) ────────────────
# Local LangGraph API. Leave blank to use the Vite /api proxy → LANGGRAPH_PORT.
# VITE_LANGGRAPH_API_URL=http://127.0.0.1:2024
VITE_LANGGRAPH_ASSISTANT_ID=agent
# Required only if the LangGraph server runs in authenticated mode
VITE_LANGSMITH_API_KEY=
VITE_DEFAULT_USER_INPUT=
VITE_DEFAULT_WEB_SEARCH=false
