# To separate your traces from other application
LANGSMITH_PROJECT=new-agent

# Groq API key (required for the agent)
GROQ_API_KEY=

# Gmail SMTP (for send_email tool — use a Gmail App Password, not your login password)
GMAIL_SMTP_USER=your.email@gmail.com
GMAIL_APP_PASSWORD="your-16-char-app-password"
GMAIL_DEFAULT_RECIPIENT=your.email@gmail.com
# Optional overrides (defaults: smtp.gmail.com / 587)
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=587

# Optional: LangSmith tracing
# LANGSMITH_API_KEY=
