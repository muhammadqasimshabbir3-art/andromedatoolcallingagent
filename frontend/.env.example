# Andromeda Agent — Frontend Environment Variables
# Set these in Vercel: Project Settings → Environment Variables

# ─── Backend URL (Vercel production) ──────────────────────────────────────────
# Use /api on Vercel — vercel.json proxies /api → Railway (avoids CORS).
# Leave unset or set exactly: /api
# VITE_LANGGRAPH_API_URL=/api
#
# Direct Railway URL only for local dev without proxy:
# VITE_LANGGRAPH_API_URL=https://andromeda-tool-calling-agent-production.up.railway.app

# Assistant / graph ID (must match the key in langgraph.json → "graphs")
VITE_LANGGRAPH_ASSISTANT_ID=agent

# ─── LangSmith API key ────────────────────────────────────────────────────────
# Required if the Railway LangGraph server is running in authenticated mode.
# Same key used on the backend (LANGSMITH_API_KEY).
VITE_LANGSMITH_API_KEY=

# ─── Optional form defaults ───────────────────────────────────────────────────
VITE_DEFAULT_USER_INPUT=
VITE_DEFAULT_WEB_SEARCH=false
