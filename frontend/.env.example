# Vercel / production frontend environment variables
# Set these in Vercel Project Settings → Environment Variables

# LangGraph API (Fly.io backend) — required in production
VITE_LANGGRAPH_API_URL=https://your-app.fly.dev
VITE_LANGGRAPH_ASSISTANT_ID=agent

# Aliases supported by frontend/src/config.ts (optional)
# VITE_API_URL=https://your-app.fly.dev
# NEXT_PUBLIC_API_URL=https://your-app.fly.dev

# Public UI URL (optional, for docs/links)
VITE_UI_URL=https://your-app.vercel.app

# Optional form defaults
VITE_DEFAULT_CHANNEL_NAME=
VITE_DEFAULT_CHANNEL_URL=
VITE_DEFAULT_MAX_REPLIES=5
VITE_DEFAULT_EMAIL_RECIPIENT=
